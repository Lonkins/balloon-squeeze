# Balloon Squeeze — environment configuration (copy to .env; .env is gitignored).
# The defaults run the full offline mock path with no key and no network.

# Provider: mock | anthropic | openai-compatible | ollama   (Phase 0 ships 'mock')
BSQ_PROVIDER=mock

# Required for cloud providers; ignored by mock/ollama. NEVER commit a real key.
BSQ_API_KEY=

# Generic model name — supplied per provider; no vendor model is ever defaulted.
BSQ_MODEL=

# Optional: base URL for openai-compatible / ollama / self-hosted endpoints.
BSQ_BASE_URL=

# Optional: integer seed for reproducible games and replays.
BSQ_SEED=

# Optional: sampling temperature (0.0 = deterministic where the provider supports it).
BSQ_TEMPERATURE=0.0

# Experiment knobs.
# Verifier arm: A0_off | A1_announced | A1_implicit | A2_silent | A3_placebo
BSQ_VERIFIER_ARM=A0_off
# Fraction of propositions marked checkable (0.0–1.0).
BSQ_CHECKABILITY_FRACTION=0.5
